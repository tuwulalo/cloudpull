# Telegram bot token from @BotFather. Copy this file to .env and fill it in.
# The .env file is gitignored, so the real token never gets committed.
BOT_TOKEN=

# Optional: parallel downloads per service (api and bot each). Defaults to a
# value tuned to the CPU cores. Raise it to push the VPS harder.
# CLOUDPULL_MAX_CONCURRENCY=8
