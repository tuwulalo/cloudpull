# Telegram bot token from @BotFather. Copy this file to .env and fill it in.
# The .env file is gitignored, so the real token never gets committed.
BOT_TOKEN=

# Optional: parallel downloads per service (api and bot each). Defaults to a
# value tuned to the CPU cores. Raise it to push the VPS harder.
# CLOUDPULL_MAX_CONCURRENCY=8

# Optional: automated Google Search Console reports (scripts/gsc_report.py).
# GSC_SA_JSON: path to the service-account key file (keep it out of git; data/ is
# gitignored, so C:\cloudpull\data\gsc-sa.json is a good spot).
# GSC_REPORT_CHAT_ID: Telegram chat to send the weekly report to. Find it with
#   python scripts/gsc_report.py --whoami   (after messaging the bot once).
# GSC_SA_JSON=C:\cloudpull\data\gsc-sa.json
# GSC_REPORT_CHAT_ID=
# GSC_PROPERTY=sc-domain:cloudpull.cloud
