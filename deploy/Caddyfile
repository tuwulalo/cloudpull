# Caddy reverse proxy for cloudpull.cloud (automatic HTTPS via Let's Encrypt).
# Security headers are applied via a snippet imported into every handle block,
# because a bare site-level `header` directive does NOT reach responses produced
# inside handle blocks.

(sec) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
	}
}

# Same as (sec) but the CSP also allows Google Fonts, which the admin UI uses.
(sec_admin) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
	}
}

cloudpull.cloud, www.cloudpull.cloud {
	# FastAPI backend (yt-dlp + ffmpeg). No compression here: downloads are
	# already-compressed audio, so gzip would only waste CPU and slow them down.
	# flush_interval -1 keeps the SSE download-progress stream flowing.
	handle /api/* {
		import sec
		reverse_proxy 127.0.0.1:8000 {
			flush_interval -1
		}
	}

	# Admin panel (served by the API). CSP allows Google Fonts used by its UI.
	handle /admin* {
		import sec_admin
		encode zstd gzip
		reverse_proxy 127.0.0.1:8000
	}

	# Next.js landing (everything else). Compress the HTML/CSS/JS.
	handle {
		import sec
		encode zstd gzip
		reverse_proxy 127.0.0.1:3000
	}
}
