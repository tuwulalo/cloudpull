# Production build values for the public deployment (cloudpull.cloud).
# These are PUBLIC, non-secret values that get inlined at build time.
# Locally, web/.env.local overrides these, so `npm run dev` still uses localhost.

NEXT_PUBLIC_SITE_URL=https://cloudpull.cloud
NEXT_PUBLIC_API_URL=https://cloudpull.cloud
NEXT_PUBLIC_REPO_URL=https://github.com/tuwulalo/cloudpull
